# ===================
# 11. DLNA (Smart TVs)
# ===================
# Servidor DLNA/UPnP para streaming a Smart TVs (Samsung Q80C, LG, Sony, PS5).
# Puerto 8200 TCP (status web + media) y 1900 UDP (SSDP discovery, fijo).
MINIDLNA_PORT="8200"
MINIDLNA_NAME="Confiraspa NAS"
# Nivel de log: "warn" para producción, "info" para depurar primer arranque
MINIDLNA_LOG_LEVEL="warn"

# ===================
# 12. MANTENIMIENTO
# ===================
# Días de retención de la papelera Samba (.recycle). Ficheros más antiguos
# se purgan automáticamente. Default: 30 días.
PRUNE_RECYCLE_DAYS="30"

# --- Backup cloud (rclone) ---
# Throttling dinámico: sin límite en horario nocturno, limitado de día.
# Horas en formato 24h sin ceros a la izquierda (0-23).
#RCLONE_BW_NIGHT_START="1"       # Hora de inicio sin límite (01:00)
#RCLONE_BW_NIGHT_END="7"         # Hora de fin sin límite (07:00)
#RCLONE_BW_DAY_LIMIT="20M"       # Límite diurno (formato rclone: 20M, 10M, 5M)
# Timeout máximo por job (subir si primera sincronización es muy grande)
#RCLONE_JOB_TIMEOUT="6h"

# ===================
# 13. FIREWALL (UFW)
# ===================
# Los puertos de arriba se usan automáticamente por firewall.sh.
# No necesitas configurar nada extra aquí. Si cambias un puerto
# de un servicio, re-ejecuta: sudo ./install.sh --only firewall