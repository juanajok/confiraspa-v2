# ==========================================
# CONFIGURACIÓN GLOBAL DE CONFIRASPA
# ==========================================
# Fichero de producción — valores reales del servidor de Juanjo.
# Generado a partir de env.example + datos del entorno actual.

# ===================
# 1. SISTEMA
# ===================
SYS_USER="pi"
SYS_PASSWORD="raspberry"
HOSTNAME="raspberrypi"
TIMEZONE="Europe/Madrid"
SSH_PORT="22"

# ===================
# 2. ALMACENAMIENTO
# ===================
# UUID del disco externo principal (obtener con: blkid)
# TODO: Rellenar con el UUID real del disco WDElements
EXTERNAL_DISK_UUID="tu-uuid-aqui"

# Rutas raíz de los discos
PATH_LIBRARY="/media/WDElements"
PATH_DOWNLOADS="/media/DiscoDuro"
PATH_BACKUP="/media/Backup"

# Rutas derivadas — Bash las expande en orden al hacer source.
# PATH_LIBRARY y PATH_DOWNLOADS DEBEN estar definidas antes.
DIR_TORRENTS="${PATH_DOWNLOADS}/torrents/completos"
DIR_TORRENTS_TEMP="${PATH_DOWNLOADS}/torrents/temp"
DIR_SERIES="${PATH_LIBRARY}/Series TV"
DIR_MOVIES="${PATH_LIBRARY}/Peliculas"
DIR_MUSIC="${PATH_LIBRARY}/Música"
DIR_BOOKS="${PATH_LIBRARY}/Libros/Biblioteca de Calibre"

# ===================
# 3. SAMBA (NAS)
# ===================
SMB_USER="${SYS_USER}"
SMB_WORKGROUP="WORKGROUP"
SMB_PASS="TuPasswordSamba"

# Nombres de los shares en el explorador de red (opcional).
# Por defecto se derivan del basename de la ruta.
SMB_SHARE_LIBRARY="WDElements"
SMB_SHARE_DOWNLOADS="Descargas"
SMB_SHARE_BACKUP="Backup"

# ===================
# 4. USUARIOS Y GRUPOS
# ===================
ARR_USER="media"
ARR_GROUP="media"

# ===================
# 5. TRANSMISSION
# ===================
TRANSMISSION_USER="transmission"
TRANSMISSION_PASS="transmission"
TRANSMISSION_PEER_PORT="51413"
TRANSMISSION_WEB_PORT="9091"

# ===================
# 6. aMULE
# ===================
AMULE_PASS="raspberry"
AMULE_WEB_PASS="raspberry"

# ===================
# 7. PLEX
# ===================
PLEX_CLAIM_TOKEN=""
PLEX_PORT="32400"

# ===================
# 8. CALIBRE
# ===================
CALIBRE_PORT="8083"

# ===================
# 9. SUITE *ARR
# ===================
SONARR_PORT="8989"
RADARR_PORT="7878"
LIDARR_PORT="8686"
READARR_PORT="8787"
PROWLARR_PORT="9696"
WHISPARR_PORT="6969"
BAZARR_PORT="6767"

# ===================
# 10. ADMINISTRACIÓN
# ===================
WEBMIN_PORT="10000"

# ===================
# 11. MANTENIMIENTO
# ===================
# Días de retención de la papelera Samba (.recycle). Ficheros más antiguos
# se purgan automáticamente. Default: 30 días.
PRUNE_RECYCLE_DAYS="30"

# ===================
# 12. FIREWALL (UFW)
# ===================
# Los puertos de arriba se usan automáticamente por firewall.sh.
# No necesitas configurar nada extra aquí. Si cambias un puerto
# de un servicio, re-ejecuta: sudo ./install.sh --only firewall