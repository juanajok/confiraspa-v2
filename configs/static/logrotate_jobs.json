{
  "jobs":[
    {
      "name": "confiraspa_backup_cloud_orchestrator",
      "path": "/var/log/rclone_backup.log",
      "rotate": 7,
      "daily": true,
      "compress": true,
      "missingok": true,
      "notifempty": true,
      "create": "0640 root adm",
      "copytruncate": true,
      "maxsize": "10M"
    },
    {
      "name": "confiraspa_backup_cloud_detail",
      "path": "/var/log/rclone_detail.log",
      "rotate": 4,
      "weekly": true,
      "compress": true,
      "missingok": true,
      "notifempty": true,
      "create": "0640 root adm",
      "copytruncate": true,
      "maxsize": "50M"
    },
    {
      "name": "confiraspa_backup_local",
      "path": "/var/log/backup_rsync.log",
      "rotate": 7,
      "daily": true,
      "compress": true,
      "missingok": true,
      "notifempty": true,
      "create": "0640 root adm",
      "copytruncate": true,
      "maxsize": "20M"
    },
    {
      "name": "confiraspa_permissions",
      "path": "/var/log/permissions_fix.log",
      "rotate": 4,
      "weekly": true,
      "compress": true,
      "missingok": true,
      "notifempty": true,
      "create": "0640 root adm",
      "copytruncate": true,
      "maxsize": "10M"
    },
    {
      "name": "confiraspa_clean_downloads",
      "path": "/var/log/clean_downloads.log",
      "rotate": 7,
      "daily": true,
      "compress": true,
      "missingok": true,
      "notifempty": true,
      "create": "0640 root adm",
      "copytruncate": true,
      "maxsize": "10M"
    },
    {
      "name": "confiraspa_prune_recycle",
      "path": "/var/log/prune_recycle.log",
      "rotate": 4,
      "weekly": true,
      "compress": true,
      "missingok": true,
      "notifempty": true,
      "create": "0640 root adm",
      "copytruncate": true,
      "maxsize": "10M"
    },
    {
      "name": "confiraspa_auto_update",
      "path": "/var/log/auto_update.log",
      "rotate": 14,
      "daily": true,
      "compress": true,
      "missingok": true,
      "notifempty": true,
      "create": "0640 root adm",
      "copytruncate": true,
      "maxsize": "10M"
    }
  ]
}