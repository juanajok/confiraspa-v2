[Unit]
Description=Prowlarr Daemon (Native)
After=network.target

[Service]
User=media
Group=media
UMask=0002
Type=simple
ExecStart=/opt/Prowlarr/Prowlarr -nobrowser -data=/var/lib/prowlarr
TimeoutStopSec=20
KillMode=process
Restart=on-failure

# Security Hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
