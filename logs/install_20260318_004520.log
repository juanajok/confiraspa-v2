# /etc/rsyncd.conf configuration file
# Configuración Gestionada por Confiraspa (v1.0 Final)

# --- Global Settings ---
uid = media
gid = media
use chroot = yes
max connections = 10
pid file = /var/run/rsyncd.pid
log file = /var/log/rsync.log
transfer logging = yes
timeout = 300
# Evita problemas de mapeo de usuarios entre distintos sistemas (Mac/Linux/Windows)
numeric ids = yes

# --- Modules ---

[Backup]
