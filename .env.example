# ==========================================
# CONFIGURACIÓN GLOBAL DE CONFIRASPA
# ==========================================
# Copia este archivo como .env y edita los valores antes de ejecutar install.sh.
# Las variables marcadas con "ChangeMe!" o "tu-..." DEBEN cambiarse.
# Las demás tienen defaults razonables y son opcionales.

# ===================
# 1. SISTEMA
# ===================
SYS_USER="pi"
SYS_PASSWORD="ChangeMe!"
HOSTNAME="raspi-server"
TIMEZONE="Europe/Madrid"
SSH_PORT="22"

# ===================
# 2. ALMACENAMIENTO
# ===================
# UUID del disco externo principal (obtener con: blkid)
EXTERNAL_DISK_UUID="tu-uuid-aqui"

# Rutas raíz de los discos
PATH_LIBRARY="/media/WDElements"
PATH_DOWNLOADS="/media/DiscoDuro"
PATH_BACKUP="/media/Backup"

# Rutas derivadas — IMPORTANTE: no escapar el $.
# Bash las expande en orden al hacer source, así que PATH_LIBRARY
# y PATH_DOWNLOADS deben estar definidas ANTES de estas líneas.
DIR_TORRENTS="${PATH_DOWNLOADS}/torrents/completos"
DIR_SERIES="${PATH_LIBRARY}/Series"
DIR_MOVIES="${PATH_LIBRARY}/Peliculas"
DIR_MUSIC="${PATH_LIBRARY}/Musica"
DIR_BOOKS="${PATH_LIBRARY}/Libros"

# ===================
# 3. SAMBA (NAS)
# ===================
SMB_USER="${SYS_USER}"
SMB_WORKGROUP="WORKGROUP"
# Solo necesaria si usas Modelo autenticado (no público).
# En modo público (guest ok = yes) no se usa.
SMB_PASS="TuPasswordSamba"

# Nombres de los shares (lo que ven los clientes en el explorador de red).
# Por defecto se derivan del basename de la ruta (ej: /media/WDElements → WDElements).
# Solo cambiar si quieres nombres más descriptivos en la red.
#SMB_SHARE_LIBRARY="WDElements"
#SMB_SHARE_DOWNLOADS="Descargas"
#SMB_SHARE_BACKUP="Backup"

# ===================
# 4. USUARIOS Y GRUPOS
# ===================
# Usuario/grupo de sistema bajo el que corren los servicios multimedia.
# NO usar "pi" — media es un usuario sin shell ni sudo, más seguro.
ARR_USER="media"
ARR_GROUP="media"

# ===================
# 5. TRANSMISSION
# ===================
TRANSMISSION_USER="admin"
TRANSMISSION_PASS="TuPasswordTransmission"
TRANSMISSION_PEER_PORT="51413"
TRANSMISSION_WEB_PORT="9091"

# ===================
# 6. aMULE
# ===================
AMULE_PASS="TuPasswordAmule"
AMULE_WEB_PASS="TuPasswordAmuleWeb"

# ===================
# 7. PLEX
# ===================
# Token de reclamación (opcional, obtener en https://www.plex.tv/claim/)
PLEX_CLAIM_TOKEN=""
PLEX_PORT="32400"

# ===================
# 8. CALIBRE
# ===================
# Puerto del Content Server integrado en la GUI
CALIBRE_PORT="8083"

# ===================
# 9. SUITE *ARR
# ===================
# Puertos estándar — solo cambiar si hay conflictos
SONARR_PORT="8989"
RADARR_PORT="7878"
LIDARR_PORT="8686"
READARR_PORT="8787"
PROWLARR_PORT="9696"
WHISPARR_PORT="6969"
BAZARR_PORT="6767"

# ===================
# 10. ADMINISTRACIÓN
# ===================
WEBMIN_PORT="10000"

# ===================
# 11. MANTENIMIENTO
# ===================
# Días de retención de la papelera Samba (.recycle). Ficheros más antiguos
# se purgan automáticamente. Default: 30 días.
#PRUNE_RECYCLE_DAYS="30"

# --- Backup cloud (rclone) ---
# Throttling dinámico: sin límite en horario nocturno, limitado de día.
# Horas en formato 24h sin ceros a la izquierda (0-23).
#RCLONE_BW_NIGHT_START="1"       # Hora de inicio sin límite (01:00)
#RCLONE_BW_NIGHT_END="7"         # Hora de fin sin límite (07:00)
#RCLONE_BW_DAY_LIMIT="20M"       # Límite diurno (formato rclone: 20M, 10M, 5M)
# Timeout máximo por job (subir si primera sincronización es muy grande)
#RCLONE_JOB_TIMEOUT="6h"

# ===================
# 12. FIREWALL (UFW)
# ===================
# Los puertos de arriba se usan automáticamente por firewall.sh.
# No necesitas configurar nada extra aquí. Si cambias un puerto
# de un servicio, re-ejecuta: sudo ./install.sh --only firewall